{
    "name": "docs",
    "projectType": "application",
    "sourceRoot": "docs",
    "targets": {
        "build": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npm run build",
                "cwd": "docs"
            }
        },
        "serve": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npm run dev",
                "cwd": "docs"
            }
        }
    }
}