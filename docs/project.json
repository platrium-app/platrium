{
    "name": "docs",
    "projectType": "application",
    "sourceRoot": "docs",
    "targets": {
        "build": {
            "executor": "nx:run-commands",
            "dependsOn": [
                "api-rest"
            ],
            "options": {
                "command": "npm install && npm run build",
                "cwd": "docs"
            }
        },
        "serve": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npm install && npm run dev",
                "cwd": "docs"
            }
        }
    }
}